GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URI=http://127.0.0.1:8844/auth/callback
HOST=127.0.0.1
PORT=8844

PYANNOTE_TOKEN=
# HF_TOKEN=

# OpenAI (optional): speech-only trim via Whisper API — set locally in .env, never commit real keys.
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1

OUTPUT_DIR=outputs
CACHE_DIR=cache_downloads
DATA_DIR=.ai-clips-web
LOG_DIR=.ai-clips-web/logs
LOG_LEVEL=INFO
LOG_MAX_MB=10
LOG_BACKUP_COUNT=5

# 0 = scheduler off
SCHEDULER_INTERVAL_MINUTES=0
AUTO_ENQUEUE_NEW_VIDEOS=false
SCHEDULER_MAX_NEW_PER_RUN=25
