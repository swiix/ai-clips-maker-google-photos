GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URI=http://127.0.0.1:8844/auth/callback
HOST=127.0.0.1
PORT=8844

PYANNOTE_TOKEN=
# HF_TOKEN=

# OpenAI (optional): prefer local JSON — copy openai_credentials.example.json to:
#   {DATA_DIR}/openai_credentials.json   (default: .ai-clips-web/openai_credentials.json)
# Optional override path: OPENAI_CREDENTIALS_JSON=/absolute/path/to/credentials.json
OPENAI_CREDENTIALS_JSON=
# Fallback if JSON missing:
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
# Cost estimate for stats (USD per minute of audio sent to transcription API)
OPENAI_WHISPER_USD_PER_MINUTE=0.006

OUTPUT_DIR=outputs
CACHE_DIR=cache_downloads
DATA_DIR=.ai-clips-web
LOG_DIR=.ai-clips-web/logs
LOG_LEVEL=INFO
LOG_MAX_MB=10
LOG_BACKUP_COUNT=5

# 0 = scheduler off
SCHEDULER_INTERVAL_MINUTES=0
AUTO_ENQUEUE_NEW_VIDEOS=false
SCHEDULER_MAX_NEW_PER_RUN=25
